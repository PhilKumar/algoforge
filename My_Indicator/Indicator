// Holiday checking function for NSE/BSE
isHoliday(_date) =>
    is_holiday = (_date == timestamp(2024, 12, 25, 15, 30) or _date == timestamp(2025, 02, 26, 15, 30) or _date == timestamp(2025, 03, 14, 15, 30) or _date == timestamp(2025, 03, 31, 15, 30) or _date == timestamp(2025, 04, 10, 15, 30) or _date == timestamp(2025, 04, 14, 15, 30) or _date == timestamp(2025, 04, 18, 15, 30) or _date == timestamp(2025, 05, 01, 15, 30) or _date == timestamp(2025, 08, 15, 15, 30) or _date == timestamp(2025, 08, 27, 15, 30) or _date == timestamp(2025, 10, 02, 15, 30) or _date == timestamp(2025, 10, 21, 15, 30) or _date == timestamp(2025, 10, 22, 15, 30) or _date == timestamp(2025, 11, 05, 15, 30) or _date == timestamp(2025, 12, 25, 15, 30))
    is_holiday

// Function to get end time for developing CPR
getNextCPREndTime() =>
    ONE_DAY = 1000 * 60 * 60 * 24
    var next_end_time = 0
    if pivotTimeframe == "1D"
        next_end_time := time_close(pivotTimeframe) + ONE_DAY
    else if pivotTimeframe == "1W"
        next_end_time := time_close(pivotTimeframe) + (ONE_DAY * 7)
    else if pivotTimeframe == "1M"
        next_end_time := time_close(pivotTimeframe) + (ONE_DAY * 30)
    else if pivotTimeframe == "3M"
        next_end_time := time_close(pivotTimeframe) + (ONE_DAY * 30 * 3)
    else if pivotTimeframe == "6M"
        next_end_time := time_close(pivotTimeframe) + (ONE_DAY * 30 * 6)
    else
        next_end_time := time_close(pivotTimeframe) + (ONE_DAY * 30 * 12)

    // Skip weekends and holidays
    while dayofweek(next_end_time) == dayofweek.saturday or dayofweek(next_end_time) == dayofweek.sunday or (checkHolidaysInput and isHoliday(next_end_time))
        next_end_time := next_end_time + ONE_DAY

    if extendNextCPRLineInput
        next_end_time := next_end_time + (ONE_DAY * nextCPRLineDaysInput)

    next_end_time

// Function to draw Next CPR line and label
drawNextCPRLineAndLabel(_price, _line_color, _text, _text_color, _style = line.style_solid) =>
    var next_start_time = 0
    next_start_time := time_close(pivotTimeframe)
    var next_end_time = 0
    next_end_time := getNextCPREndTime()

    // All lines use the same width now
    _aLine = line.new(x1=next_start_time, y1=_price, x2=next_end_time, y2=_price, xloc=xloc.bar_time, color=_line_color, width=linewidthInput, style=_style)
    line.delete(_aLine[1])

    if showLabelsInput or showPricesInput
        display_text = ""
        if showLabelsInput and showPricesInput and _text != ''
            display_text := str.format("{0} ({1})", _text, str.tostring(_price, format.mintick))
        else if showLabelsInput and _text != ''
            display_text := _text
        else if showPricesInput
            display_text := str.format("({0})", str.tostring(_price, format.mintick))
        
        // Use the same label positioning logic as main pivots
        label_x_position = positionLabelsInput == "Left" ? next_start_time : next_end_time
        label_style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left
        
        _aLabel = label.new(label_x_position, _price, xloc=xloc.bar_time, text=display_text, textcolor=_text_color, style=label_style, color=#00000000)
        label.delete(_aLabel[1])
    _aLine

//@function Draws Next CPR lines in the upcoming session timeframe.
drawNewNextCPR(startTime) =>
    // Get current session data for next CPR calculation
    [currHigh, currLow, currClose] = request.security(syminfo.tickerid, pivotTimeframe, [high, low, close], lookahead = barmerge.lookahead_on)
    
    if enableNextDayCPRSectionInput and showNextCPRInput and not na(currHigh) and not na(currLow) and not na(currClose)
        // Calculate Next CPR using current session data
        nextPivot = (currHigh + currLow + currClose) / 3.0
        nextBc = (currHigh + currLow) / 2.0
        nextTc = (nextPivot * 2) - nextBc
        
        // Draw Next CPR lines individually (TC, BC, PP)
        nextTcLine = drawNextCPRLineAndLabel(nextTc, nextTcColorInput, "TC", nextTcColorInput)
        nextBcLine = drawNextCPRLineAndLabel(nextBc, nextBcColorInput, "BC", nextBcColorInput)
        nextPpLine = drawNextCPRLineAndLabel(nextPivot, nextPpColorInput, "CPP", nextPpColorInput)
        
        float nextR1 = na
        float nextS1 = na
        float nextR2 = na
        float nextS2 = na
        float nextR3 = na
        float nextS3 = na
        float nextR4 = na
        float nextS4 = na

        // Midpoint variables
        float nextR0_5 = na  // Between PP and R1
        float nextR1_5 = na  // Between R1 and R2
        float nextR2_5 = na  // Between R2 and R3
        float nextR3_5 = na  // Between R3 and R4
        float nextS0_5 = na  // Between PP and S1
        float nextS1_5 = na  // Between S1 and S2
        float nextS2_5 = na  // Between S2 and S3
        float nextS3_5 = na  // Between S3 and S4

        // Variables to store R2 and S2 for midpoint calculation
        float tempNextR2 = na
        float tempNextS2 = na

        // Calculate and draw Next R1/S1 levels
        if showNextR1S1Input
            nextR1 := nextPivot * 2 - currLow
            nextS1 := nextPivot * 2 - currHigh
            drawNextCPRLineAndLabel(nextR1, nextR1ColorInput, "R1", nextR1ColorInput)
            drawNextCPRLineAndLabel(nextS1, nextS1ColorInput, "S1", nextS1ColorInput)

        // Calculate and draw Next R2/S2 levels
        if showNextR2S2Input
            nextR2 := nextPivot + (currHigh - currLow)  // R2 = P + (H - L)
            nextS2 := nextPivot - (currHigh - currLow)  // S2 = P - (H - L)
            tempNextR2 := nextR2
            tempNextS2 := nextS2
            drawNextCPRLineAndLabel(nextR2, nextR2ColorInput, "R2", nextR2ColorInput)
            drawNextCPRLineAndLabel(nextS2, nextS2ColorInput, "S2", nextS2ColorInput)
        else
            // Calculate R2/S2 even if not displayed, for midpoint calculation
            tempNextR2 := nextPivot + (currHigh - currLow)
            tempNextS2 := nextPivot - (currHigh - currLow)
        
        // Calculate and draw Next R3/S3 levels
        if showNextR3S3Input
            nextR3 := currHigh + 2 * (nextPivot - currLow)  // R3 = H + 2(P - L)
            nextS3 := currLow - 2 * (currHigh - nextPivot)  // S3 = L - 2(H - P)
            drawNextCPRLineAndLabel(nextR3, nextR3ColorInput, "R3", nextR3ColorInput)
            drawNextCPRLineAndLabel(nextS3, nextS3ColorInput, "S3", nextS3ColorInput)
        
        // Calculate and draw Next R4/S4 levels
        if showNextR4S4Input
            nextR4 := nextR3 + (nextR1 - nextPivot)  // R4 = R3 + (R1 - P)
            nextS4 := nextS3 - (nextPivot - nextS1)  // S4 = S3 - (P - S1)
            drawNextCPRLineAndLabel(nextR4, nextR4ColorInput, "R4", nextR4ColorInput)
            drawNextCPRLineAndLabel(nextS4, nextS4ColorInput, "S4", nextS4ColorInput)
        
        // Draw Next Day Midpoint levels
        if showNextMidpointsInput
            // Next R0.5/S0.5 (between PP and R1/S1)
            if showNextR0_5S0_5Input and not na(nextPivot) and not na(nextR1) and not na(nextS1)
                nextR0_5 := math.avg(nextPivot, nextR1)
                nextS0_5 := math.avg(nextPivot, nextS1)
                drawNextCPRLineAndLabel(nextR0_5, nextR0_5ColorInput, "R0.5", nextR0_5ColorInput, line.style_dotted)
                drawNextCPRLineAndLabel(nextS0_5, nextS0_5ColorInput, "S0.5", nextS0_5ColorInput, line.style_dotted)
            
            // Next R1.5/S1.5 (between R1/S1 and R2/S2)
            if showNextR1_5S1_5Input and not na(nextR1) and not na(tempNextR2) and not na(nextS1) and not na(tempNextS2)
                nextR1_5 := math.avg(nextR1, tempNextR2)
                nextS1_5 := math.avg(nextS1, tempNextS2)
                drawNextCPRLineAndLabel(nextR1_5, nextR1_5ColorInput, "R1.5", nextR1_5ColorInput, line.style_dotted)
                drawNextCPRLineAndLabel(nextS1_5, nextS1_5ColorInput, "S1.5", nextS1_5ColorInput, line.style_dotted)
            
            // Next R2.5/S2.5 (between R2/S2 and R3/S3)
            if showNextR2_5S2_5Input and not na(tempNextR2) and not na(nextR3) and not na(tempNextS2) and not na(nextS3)
                nextR2_5 := math.avg(tempNextR2, nextR3)
                nextS2_5 := math.avg(tempNextS2, nextS3)
                drawNextCPRLineAndLabel(nextR2_5, nextR2_5ColorInput, "R2.5", nextR2_5ColorInput, line.style_dotted)
                drawNextCPRLineAndLabel(nextS2_5, nextS2_5ColorInput, "S2.5", nextS2_5ColorInput, line.style_dotted)
        
        // Draw Next PDH/PDL levels (current session high/low become next session's previous day levels)
        if showNextPrevDayInput
            drawNextCPRLineAndLabel(currHigh, nextPdhColorInput, "PDH", nextPdhColorInput, line.style_dotted)
            drawNextCPRLineAndLabel(currLow, nextPdlColorInput, "PDL", nextPdlColorInput, line.style_dotted)


