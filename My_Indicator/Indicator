                newCPRGraphics.push(pivotGraphic.new(r3_5Line, r3_5Label))
                newCPRGraphics.push(pivotGraphic.new(s3_5Line, s3_5Label))
    
    drawnCPRGraphics.add_row(array_id = newCPRGraphics)

    if drawnCPRGraphics.rows() > maxHistoricalPivotsInput
        oldCPRGraphics = drawnCPRGraphics.remove_row(0)
        
        for graphic in oldCPRGraphics
            graphic.delete()

