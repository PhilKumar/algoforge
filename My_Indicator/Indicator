    timeframe.isintraday => timeframe.multiplier <= 15 ? "1D" : "1W"
    timeframe.isdaily    => "1M"
    => "12M"

pivotTimeframe = switch pivotAnchorInput
    "Auto"      => autoAnchor
    "Daily"     => "1D"
    "Weekly"    => "1W"
    "Monthly"   => "1M"
    "Quarterly" => "3M"
    => "12M"

//@variable The number of years in the selected Pivot period
pivotYearMultiplier = switch pivotAnchorInput
    "Biyearly"       => 2
    "Triyearly"      => 3
    "Quinquennially" => 5
    "Decennially"    => 10
    => 1

//@variable The number of values in the pivots of the selected type
numOfPivotLevels = switch pivotTypeInput
    "Traditional" => 11
    "Camarilla"   => 11
    "Woodie"      => 9
    "Classic"     => 9
    "Fibonacci"   => 7
    "DM"          => 3

type pivotGraphic
    line pivotLine
    label pivotLabel

method delete(pivotGraphic graphic) =>
    graphic.pivotLine.delete()
    graphic.pivotLabel.delete()

// Variables for Initial Balance and previous values

var float ib4hHigh = na
var float ib4hLow = na
var int ib4hSessionStart = na
var int ib4hSessionEnd = na

var float prevIb4hHigh = na
var float prevIb4hLow = na
var int prevIb4hStart = na

var float ib1hHigh = na
var float ib1hLow = na
var int ib1hSessionStart = na
var int ib1hSessionEnd = na

var drawnGraphics = matrix.new<pivotGraphic>()
var drawnCPRGraphics = matrix.new<pivotGraphic>()
var drawnPrevDayGraphics = matrix.new<pivotGraphic>()
var drawnIBGraphics = matrix.new<pivotGraphic>()
var drawnAdditionalTF1Graphics = matrix.new<pivotGraphic>()
var drawnAdditionalTF2Graphics = matrix.new<pivotGraphic>()
var drawnAdditionalTF3Graphics = matrix.new<pivotGraphic>()

localPivotTimeframeChange = timeframe.change(pivotTimeframe) and year % pivotYearMultiplier == 0
securityPivotTimeframeChange = timeframe.change(timeframe.period) and year % pivotYearMultiplier == 0

pivotTimeframeChangeCounter(condition) => 
    var count = 0
    if condition and bar_index > 0
        count += 1
    count

localPivots = ta.pivot_point_levels(pivotTypeInput, localPivotTimeframeChange)
securityPivotPointsArray = ta.pivot_point_levels(pivotTypeInput, securityPivotTimeframeChange)

securityTimeframe = timeframe.isintraday ? "1D" : timeframe.period
[securityPivots, securityPivotCounter] = request.security(syminfo.tickerid, pivotTimeframe, [securityPivotPointsArray, pivotTimeframeChangeCounter(securityPivotTimeframeChange)], lookahead = barmerge.lookahead_on)
pivotPointsArray = isDailyBasedInput ? securityPivots : localPivots

// Get OHLC for CPR calculation
[securityHigh, securityLow, securityClose] = request.security(syminfo.tickerid, pivotTimeframe, [high[1], low[1], close[1]], lookahead = barmerge.lookahead_on)
localHigh = high[1]
localLow = low[1] 
localClose = close[1]

cprHigh = isDailyBasedInput ? securityHigh : localHigh
cprLow = isDailyBasedInput ? securityLow : localLow
cprClose = isDailyBasedInput ? securityClose : localClose

// Calculate CPR levels
pivot = (cprHigh + cprLow + cprClose) / 3
bc = (cprHigh + cprLow) / 2
tc = (pivot - bc) + pivot

// Calculate EMA values
ema1 = ta.ema(close, ema1LengthInput)
ema2 = ta.ema(close, ema2LengthInput)
ema3 = ta.ema(close, ema3LengthInput)

// Calculate Custom Supertrend
atr2 = ta.sma(ta.tr, supertrendPeriodInput)
atr = changeATRInput ? ta.atr(supertrendPeriodInput) : atr2
up = supertrendSourceInput - (supertrendFactorInput * atr)
up1 = nz(up[1], up)
up := close[1] > up1 ? math.max(up, up1) : up
dn = supertrendSourceInput + (supertrendFactorInput * atr)
dn1 = nz(dn[1], dn)
dn := close[1] < dn1 ? math.min(dn, dn1) : dn
var int trend = 1
trend := nz(trend[1], trend)
trend := trend == -1 and close > dn1 ? 1 : trend == 1 and close < up1 ? -1 : trend
supertrend = trend == 1 ? up : dn
supertrendColor = trend == 1 ? supertrendUpColorInput : supertrendDownColorInput

// Buy/Sell Signals
buySignal = trend == 1 and trend[1] == -1
sellSignal = trend == -1 and trend[1] == 1

// Calculate VWAP
vwapValue = ta.vwap(close)

// Initialize variables for Initial Balance tracking
// Current IB variables


// Get current bar's time in IST
currentHour = hour(time, "Asia/Kolkata")
currentMinute = minute(time, "Asia/Kolkata")

// Session Detection
is1hIBTime = (currentHour == 9 and currentMinute >= 15) or 
             (currentHour == 10 and currentMinute <= 15)

// 4H Session logic with exact conditions
is4hIBTime = (currentHour == 5 and currentMinute >= 30) or 
             (currentHour == 6) or 
             (currentHour == 7) or 
             (currentHour == 8) or 
             (currentHour == 9 and currentMinute <= 30)

// Track 1H Initial Balance (9:15-10:15)
if currentHour == 9 and currentMinute == 15 and not(hour(time[1], "Asia/Kolkata") == 9 and minute(time[1], "Asia/Kolkata") == 15)
    ib1hHigh := high
    ib1hLow := low
    ib1hSessionStart := time
else if is1hIBTime
    ib1hHigh := math.max(ib1hHigh, high)
    ib1hLow := math.min(ib1hLow, low)
if currentHour == 10 and currentMinute == 15
    ib1hSessionEnd := time

// Track 4H Initial Balance (5:30-9:30)
if currentHour == 5 and currentMinute == 30
    ib4hHigh := high
    ib4hLow := low
    ib4hSessionStart := time
    label.new(bar_index, high, text="4H Start", style=label.style_none, textcolor=color.white)
else if is4hIBTime
    ib4hHigh := math.max(ib4hHigh, high)
    ib4hLow := math.min(ib4hLow, low)
if currentHour == 9 and currentMinute == 30
    ib4hSessionEnd := time
    // Store previous day's values when session ends
    if not na(ib4hHigh) and not na(ib4hLow)
        prevIb4hHigh := ib4hHigh
        prevIb4hLow := ib4hLow
        prevIb4hStart := ib4hSessionStart

// Define session flags for condition checks
isIB1HSession = is1hIBTime
isIB4HSession = is4hIBTime

