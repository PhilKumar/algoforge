//@function Draws pivot lines and labels from `startTime` to the approximate end of the period.
drawNewPivots(startTime) =>
    
    newGraphics = array.new<pivotGraphic>()

    for [index, coord] in pivotPointsArray
        levelSettings = graphicSettingsArray.get(index)
        if not na(coord) and levelSettings.showLevel
            lineEndTime = startTime + timeframe.in_seconds(pivotTimeframe) * 1000 * pivotYearMultiplier
            pivotLine = line.new(startTime, coord, lineEndTime, coord, xloc = xloc.bar_time, color=levelSettings.levelColor, width=linewidthInput)
            pivotLabel = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                               y = coord,
                               text = (showLabelsInput ? levelSettings.levelName + " " : "") + (showPricesInput ? "(" + str.tostring(coord, format.mintick) + ")" : ""),
                               style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                               textcolor = levelSettings.levelColor,
                               color = #00000000,
                               xloc=xloc.bar_time)
            
            newGraphics.push(pivotGraphic.new(pivotLine, pivotLabel))
    
    drawnGraphics.add_row(array_id = newGraphics)

    if drawnGraphics.rows() > maxHistoricalPivotsInput
        oldGraphics = drawnGraphics.remove_row(0)
        
        for graphic in oldGraphics
            graphic.delete()

//@function Draws CPR lines and labels from `startTime` to the approximate end of the period.
drawNewCPR(startTime) =>
    
    newCPRGraphics = array.new<pivotGraphic>()

    if enableMainCPRSectionInput and showCPRInput and not na(tc) and not na(bc) and not na(pivot)
        lineEndTime = startTime + timeframe.in_seconds(pivotTimeframe) * 1000 * pivotYearMultiplier
        
        // Draw TC line
        tcLine = line.new(startTime, tc, lineEndTime, tc, xloc = xloc.bar_time, color=tcColorInput, width=linewidthInput)
        tcLabel = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                           y = tc,
                           text = (showLabelsInput ? "TC " : "") + (showPricesInput ? "(" + str.tostring(tc, format.mintick) + ")" : ""),
                           style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                           textcolor = tcColorInput,
                           color = #00000000,
                           xloc=xloc.bar_time)
        
        // Draw BC line
        bcLine = line.new(startTime, bc, lineEndTime, bc, xloc = xloc.bar_time, color=bcColorInput, width=linewidthInput)
        bcLabel = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                           y = bc,
                           text = (showLabelsInput ? "BC " : "") + (showPricesInput ? "(" + str.tostring(bc, format.mintick) + ")" : ""),
                           style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                           textcolor = bcColorInput,
                           color = #00000000,
                           xloc=xloc.bar_time)
        
        // Draw PP (Central Pivot) line
        ppLine = line.new(startTime, pivot, lineEndTime, pivot, xloc = xloc.bar_time, color=ppColorInput, width=linewidthInput)
        ppLabel = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                           y = pivot,
                           text = (showLabelsInput ? "PP " : "") + (showPricesInput ? "(" + str.tostring(pivot, format.mintick) + ")" : ""),
                           style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                           textcolor = ppColorInput,
                           color = #00000000,
                           xloc=xloc.bar_time)

        newCPRGraphics.push(pivotGraphic.new(tcLine, tcLabel))
        newCPRGraphics.push(pivotGraphic.new(bcLine, bcLabel))
        newCPRGraphics.push(pivotGraphic.new(ppLine, ppLabel))

    // Calculate and draw R1-R4 and S1-S4 levels (independent of CPR toggle)
    if not na(tc) and not na(bc) and not na(pivot)
        lineEndTime = startTime + timeframe.in_seconds(pivotTimeframe) * 1000 * pivotYearMultiplier
        r1 = 2 * pivot - cprLow
        s1 = 2 * pivot - cprHigh
        r2 = pivot + (cprHigh - cprLow)
        s2 = pivot - (cprHigh - cprLow)
        r3 = cprHigh + 2 * (pivot - cprLow)
        s3 = cprLow - 2 * (cprHigh - pivot)
        r4 = r3 + (r1 - pivot)
        s4 = s3 - (pivot - s1)

        // Draw midpoint lines (independent of main pivot toggle)
        if enableMainCPRSectionInput and showMidpointsInput
            // R0.5 and S0.5
            if showR0_5S0_5Input
                r0_5 = math.avg(pivot, r1)
                s0_5 = math.avg(pivot, s1)
                r0_5Line = line.new(startTime, r0_5, lineEndTime, r0_5, xloc = xloc.bar_time, color=r0_5ColorInput, width=linewidthInput, style=line.style_dotted)
                s0_5Line = line.new(startTime, s0_5, lineEndTime, s0_5, xloc = xloc.bar_time, color=s0_5ColorInput, width=linewidthInput, style=line.style_dotted)
                r0_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                           y = r0_5,
                           text = (showLabelsInput ? "R0.5 " : "") + (showPricesInput ? "(" + str.tostring(r0_5, format.mintick) + ")" : ""),
                           style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                           textcolor = r0_5ColorInput,
                           color = #00000000,
                           xloc=xloc.bar_time)
                s0_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                           y = s0_5,
                           text = (showLabelsInput ? "S0.5 " : "") + (showPricesInput ? "(" + str.tostring(s0_5, format.mintick) + ")" : ""),
                           style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                           textcolor = s0_5ColorInput,
                           color = #00000000,
                           xloc=xloc.bar_time)
                newCPRGraphics.push(pivotGraphic.new(r0_5Line, r0_5Label))
                newCPRGraphics.push(pivotGraphic.new(s0_5Line, s0_5Label))

            // R1.5 and S1.5 between R1/S1 and R2/S2
            if showR1_5S1_5Input and not na(r1) and not na(r2) and not na(s1) and not na(s2)
                r1_5 = math.avg(r1, r2)
                s1_5 = math.avg(s1, s2)
                r1_5Line = line.new(startTime, r1_5, lineEndTime, r1_5, xloc = xloc.bar_time, color=r1_5ColorInput, width=linewidthInput, style=line.style_dotted)
                s1_5Line = line.new(startTime, s1_5, lineEndTime, s1_5, xloc = xloc.bar_time, color=s1_5ColorInput, width=linewidthInput, style=line.style_dotted)
                r1_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                                   y = r1_5,
                                   text = (showLabelsInput ? "R1.5 " : "") + (showPricesInput ? "(" + str.tostring(r1_5, format.mintick) + ")" : ""),
                                   style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                                   textcolor = r1_5ColorInput,
                                   color = #00000000,
                                   xloc=xloc.bar_time)
                s1_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                                   y = s1_5,
                                   text = (showLabelsInput ? "S1.5 " : "") + (showPricesInput ? "(" + str.tostring(s1_5, format.mintick) + ")" : ""),
                                   style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                                   textcolor = s1_5ColorInput,
                                   color = #00000000,
                                   xloc=xloc.bar_time)
                newCPRGraphics.push(pivotGraphic.new(r1_5Line, r1_5Label))
                newCPRGraphics.push(pivotGraphic.new(s1_5Line, s1_5Label))

                // R2.5 and S2.5 between R2/S2 and R3/S3
                if showR2_5S2_5Input and not na(r2) and not na(r3) and not na(s2) and not na(s3)
                    r2_5 = math.avg(r2, r3)
                    s2_5 = math.avg(s2, s3)
                    r2_5Line = line.new(startTime, r2_5, lineEndTime, r2_5, xloc = xloc.bar_time, color=r2_5ColorInput, width=linewidthInput, style=line.style_dotted)
                    s2_5Line = line.new(startTime, s2_5, lineEndTime, s2_5, xloc = xloc.bar_time, color=s2_5ColorInput, width=linewidthInput, style=line.style_dotted)
                    r2_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                                       y = r2_5,
                                       text = (showLabelsInput ? "R2.5 " : "") + (showPricesInput ? "(" + str.tostring(r2_5, format.mintick) + ")" : ""),
                                       style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                                       textcolor = r2_5ColorInput,
                                       color = #00000000,
                                       xloc=xloc.bar_time)
                    s2_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                                       y = s2_5,
                                       text = (showLabelsInput ? "S2.5 " : "") + (showPricesInput ? "(" + str.tostring(s2_5, format.mintick) + ")" : ""),
                                       style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                                       textcolor = s2_5ColorInput,
                                       color = #00000000,
                                       xloc=xloc.bar_time)
                    newCPRGraphics.push(pivotGraphic.new(r2_5Line, r2_5Label))
                    newCPRGraphics.push(pivotGraphic.new(s2_5Line, s2_5Label))

            if showR3_5S3_5Input and not na(r3) and not na(r4) and not na(s3) and not na(s4)
                r3_5 = math.avg(r3, r4)
                s3_5 = math.avg(s3, s4)
                r3_5Line = line.new(startTime, r3_5, lineEndTime, r3_5, xloc = xloc.bar_time, color=r3_5ColorInput, width=linewidthInput, style=line.style_dotted)
                s3_5Line = line.new(startTime, s3_5, lineEndTime, s3_5, xloc = xloc.bar_time, color=s3_5ColorInput, width=linewidthInput, style=line.style_dotted)
                r3_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                               y = r3_5,
                                   text = (showLabelsInput ? "R3.5 " : "") + (showPricesInput ? "(" + str.tostring(r3_5, format.mintick) + ")" : ""),
                                   style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                                   textcolor = r3_5ColorInput,
                                   color = #00000000,
                               xloc=xloc.bar_time)
                s3_5Label = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                                   y = s3_5,
                                   text = (showLabelsInput ? "S3.5 " : "") + (showPricesInput ? "(" + str.tostring(s3_5, format.mintick) + ")" : ""),
                                   style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
