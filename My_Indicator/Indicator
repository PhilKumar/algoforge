//@function Calculate timeframe duration in milliseconds
getTimeframeDuration(tf) =>
    switch tf
        "1" => 1 * 60 * 1000              // 1 minute
        "3" => 3 * 60 * 1000              // 3 minutes
        "5" => 5 * 60 * 1000              // 5 minutes
        "15" => 15 * 60 * 1000            // 15 minutes
        "30" => 30 * 60 * 1000            // 30 minutes
        "45" => 45 * 60 * 1000            // 45 minutes
        "60" => 1 * 60 * 60 * 1000        // 1 hour
        "120" => 2 * 60 * 60 * 1000       // 2 hours
        "180" => 3 * 60 * 60 * 1000       // 3 hours
        "240" => 4 * 60 * 60 * 1000       // 4 hours
        "D" => 24 * 60 * 60 * 1000        // 1 day
        "W" => 7 * 24 * 60 * 60 * 1000    // 1 week
        "M" => 30 * 24 * 60 * 60 * 1000   // 1 month
        => 24 * 60 * 60 * 1000            // default 1 day

//@function Draw CPR lines for additional timeframe with historical tracking
drawAdditionalCPR(tf, showTF, showPivots, tcColor, bcColor, ppColor, rColor, sColor, tfLabel, graphicsMatrix) =>
    if enableAdditionalCPRTimeframesInput and showAdditionalCPRInput and showTF and extendAdditionalCPRLinesInput
        // Get OHLC from the specified timeframe
        [tfHigh, tfLow, tfClose] = request.security(syminfo.tickerid, tf, [high[1], low[1], close[1]], lookahead = barmerge.lookahead_on)
        
        // Get timeframe boundaries
        tfTime = request.security(syminfo.tickerid, tf, time, lookahead = barmerge.lookahead_on)
        bool newTfPeriod = ta.change(tfTime) != 0
        
        if newTfPeriod and not na(tfHigh) and not na(tfLow) and not na(tfClose)
            // Calculate CPR levels
            tfPivot = (tfHigh + tfLow + tfClose) / 3
            tfBc = (tfHigh + tfLow) / 2
            tfTc = (tfPivot - tfBc) + tfPivot
            
            // Calculate R1-R4 and S1-S4 levels
            tfR1 = 2 * tfPivot - tfLow
            tfS1 = 2 * tfPivot - tfHigh
            tfR2 = tfPivot + (tfHigh - tfLow)
            tfS2 = tfPivot - (tfHigh - tfLow)
            tfR3 = tfHigh + 2 * (tfPivot - tfLow)
            tfS3 = tfLow - 2 * (tfHigh - tfPivot)
            tfR4 = tfR3 + (tfR1 - tfPivot)
            tfS4 = tfS3 - (tfPivot - tfS1)
            
            // Calculate time boundaries
            int tfDuration = getTimeframeDuration(tf)
            int tfStartTime = int(time)
            int tfEndTime = int(time) + tfDuration
            
            // Create new graphics array for this period
            newTfGraphics = array.new<pivotGraphic>()
            
            // Draw CPR lines extending to end of timeframe
            tfTcLine = line.new(x1=tfStartTime, y1=tfTc, x2=tfEndTime, y2=tfTc, xloc=xloc.bar_time, color=tcColor, width=2, style=line.style_solid)
            tfBcLine = line.new(x1=tfStartTime, y1=tfBc, x2=tfEndTime, y2=tfBc, xloc=xloc.bar_time, color=bcColor, width=2, style=line.style_solid)
            tfCpLine = line.new(x1=tfStartTime, y1=tfPivot, x2=tfEndTime, y2=tfPivot, xloc=xloc.bar_time, color=ppColor, width=2, style=line.style_solid)
            
            // Add CPR lines to graphics array (with dummy labels)
            newTfGraphics.push(pivotGraphic.new(tfTcLine, label.new(tfStartTime, tfTc, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
            newTfGraphics.push(pivotGraphic.new(tfBcLine, label.new(tfStartTime, tfBc, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
            newTfGraphics.push(pivotGraphic.new(tfCpLine, label.new(tfStartTime, tfPivot, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
            
            // Draw pivot lines if enabled
            if showPivots
                tfR1Line = line.new(x1=tfStartTime, y1=tfR1, x2=tfEndTime, y2=tfR1, xloc=xloc.bar_time, color=rColor, width=1, style=line.style_solid)
                tfS1Line = line.new(x1=tfStartTime, y1=tfS1, x2=tfEndTime, y2=tfS1, xloc=xloc.bar_time, color=sColor, width=1, style=line.style_solid)
                tfR2Line = line.new(x1=tfStartTime, y1=tfR2, x2=tfEndTime, y2=tfR2, xloc=xloc.bar_time, color=rColor, width=1, style=line.style_solid)
                tfS2Line = line.new(x1=tfStartTime, y1=tfS2, x2=tfEndTime, y2=tfS2, xloc=xloc.bar_time, color=sColor, width=1, style=line.style_solid)
                tfR3Line = line.new(x1=tfStartTime, y1=tfR3, x2=tfEndTime, y2=tfR3, xloc=xloc.bar_time, color=rColor, width=1, style=line.style_solid)
                tfS3Line = line.new(x1=tfStartTime, y1=tfS3, x2=tfEndTime, y2=tfS3, xloc=xloc.bar_time, color=sColor, width=1, style=line.style_solid)
                tfR4Line = line.new(x1=tfStartTime, y1=tfR4, x2=tfEndTime, y2=tfR4, xloc=xloc.bar_time, color=rColor, width=1, style=line.style_solid)
                tfS4Line = line.new(x1=tfStartTime, y1=tfS4, x2=tfEndTime, y2=tfS4, xloc=xloc.bar_time, color=sColor, width=1, style=line.style_solid)
                
                // Add pivot lines to graphics array (with dummy labels)
                newTfGraphics.push(pivotGraphic.new(tfR1Line, label.new(tfStartTime, tfR1, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfS1Line, label.new(tfStartTime, tfS1, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfR2Line, label.new(tfStartTime, tfR2, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfS2Line, label.new(tfStartTime, tfS2, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfR3Line, label.new(tfStartTime, tfR3, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfS3Line, label.new(tfStartTime, tfS3, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfR4Line, label.new(tfStartTime, tfR4, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
                newTfGraphics.push(pivotGraphic.new(tfS4Line, label.new(tfStartTime, tfS4, xloc=xloc.bar_time, color=#00000000, textcolor=#00000000, style=label.style_none)))
            
            // Add this period's graphics to the matrix
            graphicsMatrix.add_row(array_id = newTfGraphics)
            
            // Remove old periods if we exceed the maximum
            if graphicsMatrix.rows() > maxHistoricalPivotsInput
                oldTfGraphics = graphicsMatrix.remove_row(0)
                for graphic in oldTfGraphics
                    graphic.delete()

